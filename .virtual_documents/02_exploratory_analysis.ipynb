# Quick dtype + missing value overview
dtype_summary = pd.DataFrame({
    "dtype": df.dtypes,
    "missing_n": df.isna().sum(),
    "missing_%": (df.isna().sum() / len(df) * 100).round(2),
    "unique_n": df.nunique()
})
