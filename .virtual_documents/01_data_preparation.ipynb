df_in = separateMonthYear(df_in)





def dateTime(df):
    '''Converts df["DateTime"] into datetime-object
    ARGS:
        df: Dataframe
    RETURN:
        None
    '''
    if "DateTime" in df:
        df_clean = df.copy()
        df_clean["DateTime"] = pd.to_datetime(df_clean["DateTime"], format='%m/%d/%Y %I:%M:%S %p')
        return df_clean
    else:
        print("DateTime is not in df.columns")
        return df


